# Seva environment — copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# Values below are placeholders only; no real secrets belong in this file.

# --- Supabase (client) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (server-only) ---
# Service-role key BYPASSES RLS. Used only by app/api/** via lib/supabase-admin.ts.
# Must NOT be prefixed NEXT_PUBLIC_ and must never reach the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Razorpay (Step 5 escrow) — TEST keys only until you deliberately go live ---
# Public: used by Razorpay Checkout on the client.
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
# SECRET — server only. Signs order/refund calls.
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
# SECRET — server only. Must match the webhook secret set in the Razorpay dashboard;
# the webhook route verifies X-Razorpay-Signature against it.
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
